</div>

<div class="w3-row-padding w3-padding w3-container w3-margin-bottom w3-black">
  <div class="w3-content">
    <br><br><br>

    <!-- Wrapper containing horseshoe spread and copy panel -->
    <div class="tarot-wrapper">
      
      <!-- Horseshoe Spread -->
      <div class="horseshoe-container" style="padding-bottom:0px; margin-bottom:0px;">
        <!-- Center image and buttons -->
        <div class="center-text w3-card w3-padding-32">
          <div class="w3-padding-small"><button class="w3-button" onclick="shuffleDeck()" id="shuffle" title="shuffle cards">shuffle</button></div>
