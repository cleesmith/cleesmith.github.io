<!DOCTYPE html>
<html lang="en">
<head>
  <title>Slip the Trap</title>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="shortcut icon" href="images/me-hermit-1-121x119.png" type="image/x-icon">
  <meta name="description" content="personal website for slip the trap">

  <link rel="stylesheet" href="css/w3.css">
  <link href="fontawesome/css/all.min.css" rel="stylesheet">
  
  <style>
    /* Wrapper to keep horseshoe and copy panel together */
    .tarot-wrapper {
      max-width: min(96vw, 900px);
      margin: 0 auto;
    }

    /* Horseshoe Spread Layout */
    .horseshoe-container {
      position: relative;
      padding: clamp(12px, 2vh, 28px);
      padding-bottom: 0; /* removes bottom padding */
      min-height: clamp(500px, 68vh, 650px);
    }
    
    .card-position {
      position: absolute;
      width: clamp(85px, 10vw, 130px);
      transition: transform 0.3s ease;
      padding: 5px;
    }
    
    .card-position img {
      width: 100%;
      cursor: pointer;
      border-radius: 8px;
    }

    .card-position h6 {
      display: none;
    }
    
    #position-you:hover {
      transform: translateX(-50%) scale(1.05);
    }

    #position-future:hover {
      transform: rotate(-90deg) scale(1.05);
    }

    #position-setting:hover {
      transform: rotate(90deg) scale(1.05);
    }

    #position-present:hover {
      transform: rotate(-90deg) scale(1.05);
    }

    #position-obstacles:hover {
      transform: rotate(90deg) scale(1.05);
    }

    #position-past:hover {
      transform: rotate(-90deg) scale(1.05);
    }

    #position-outcome:hover {
      transform: rotate(90deg) scale(1.05);
    }
    
    .card-label {
      position: absolute;
      font-style: italic;
      color: white;
      font-size: 11px;
      font-weight: normal;
      white-space: nowrap;
      opacity: 0;
      transition: opacity 0.3s ease;
      pointer-events: none;
      background-color: rgba(0, 0, 0, 0.7);
      padding: 3px 6px;
      border-radius: 3px;
    }

    .card-position:hover + .card-label {
      opacity: 1;
    }
    
    /* Card positions for horseshoe spread */
    #position-you {
      top: 3%;
      left: 50%;
      transform: translateX(-50%);
    }

    #position-future {
      top: 12%;
      left: 15%;
      transform: rotate(-90deg);
    }

    #position-setting {
      top: 12%;
      right: 15%;
      transform: rotate(90deg);
    }

    #position-present {
      top: 35%;
      left: 15%;
      transform: rotate(-90deg);
    }

    #position-obstacles {
      top: 35%;
      right: 15%;
      transform: rotate(90deg);
    }

    #position-past {
      top: 58%;
      left: 15%;
      transform: rotate(-90deg);
    }

    #position-outcome {
      top: 58%;
      right: 15%;
      transform: rotate(90deg);
    }
    
    /* Labels */
    #label-you {
      top: 20%;
      left: 50%;
      transform: translateX(-50%);
    }

    #label-future {
      top: 22%;
      left: 15%;
      transform: translateX(-50%);
    }

    #label-setting {
      top: 22%;
      right: 15%;
      transform: translateX(50%);
    }

    #label-present {
      top: 45%;
      left: 15%;
      transform: translateX(-50%);
    }

    #label-obstacles {
      top: 45%;
      right: 15%;
      transform: translateX(50%);
    }

    #label-past {
      top: 68%;
      left: 15%;
      transform: translateX(-50%);
    }

    #label-outcome {
      top: 68%;
      right: 15%;
      transform: translateX(50%);
    }
    
    /* Center text */
    .center-text {
      position: absolute;
      top: 37%;
      left: 50%;
      transform: translateX(-50%);
      text-align: center;
      color: white;
      z-index: 10;
    }

    .center-text img {
      border-radius: 8px;
      width: clamp(75px, 9vw, 110px);
      min-width: 0;
      max-width: none;
    }

    .center-text .w3-button {
      padding: 4px 10px;
      background-color: #2a2a2a;
      color: #ffffff;
      border: 1px solid #3a3a3a;
      border-radius: 6px;
      font-size: 13px;
      font-weight: 500;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      margin: 0 4px;
      transition: background-color 0.2s ease;
    }

    .center-text .w3-button:hover {
      background-color: #333333;
    }

    /* Copy panel below horseshoe-container */
    #copyPanel {
      padding: 0 clamp(12px, 2vh, 28px);
      margin-top: 0;
    }

    #copyPanel .w3-card-4 {
      max-width: 550px;
      margin: 0 auto;
      border: 1px solid #555;
      background-color: #1a1a1a;
    }

    #copyPanel .w3-container {
      padding: 10px 15px;
    }

    #copyPanel #spreadCards {
      font-size: 12px;
      line-height: 1.4;
      margin: 0;
      color: #ccc;
    }

    #copyPanel #copyFooter {
      cursor: pointer;
      padding: 10px 15px;
    }

    #copyPanel #copyText {
      font-size: 14px;
      margin: 0;
    }

    /* Modal overlay */
    #modal01 {
      z-index: 10000 !important;
    }
    
    .center-text h2 {
      font-size: 24px;
      margin-bottom: 10px;
    }
    
    .center-text p {
      font-size: 16px;
      line-height: 1.6;
    }
    
    /* Responsive adjustments */
    @media (max-width: 768px) {
      .horseshoe-container {
        min-height: clamp(550px, 70vh, 700px);
      }

      .card-position {
        width: clamp(65px, 18vw, 95px);
      }

      .center-text img {
        width: clamp(60px, 15vw, 90px);
      }
      
      .card-label {
        font-size: 9px;
      }
      
      #position-you {
        top: 3%;
      }

      #position-future {
        top: 12%;
        left: 10%;
        transform: rotate(-90deg);
      }

      #position-setting {
        top: 12%;
        right: 10%;
        transform: rotate(90deg);
      }

      #position-present {
        top: 35%;
        left: 10%;
        transform: rotate(-90deg);
      }

      #position-obstacles {
        top: 35%;
        right: 10%;
        transform: rotate(90deg);
      }

      #position-past {
        top: 58%;
        left: 10%;
        transform: rotate(-90deg);
      }

      #position-outcome {
        top: 58%;
        right: 10%;
        transform: rotate(90deg);
      }

      #position-you:hover {
        transform: translateX(-50%) scale(1.05);
      }

      #position-future:hover {
        transform: rotate(-90deg) scale(1.05);
      }

      #position-setting:hover {
        transform: rotate(90deg) scale(1.05);
      }

      #position-present:hover {
        transform: rotate(-90deg) scale(1.05);
      }

      #position-obstacles:hover {
        transform: rotate(90deg) scale(1.05);
      }

      #position-past:hover {
        transform: rotate(-90deg) scale(1.05);
      }

      #position-outcome:hover {
        transform: rotate(90deg) scale(1.05);
      }

      #label-you {
        top: 20%;
      }

      #label-future {
        top: 22%;
        left: 10%;
        transform: translateX(-50%);
      }

      #label-setting {
        top: 22%;
        right: 10%;
        transform: translateX(50%);
      }

      #label-present {
        top: 45%;
        left: 10%;
        transform: translateX(-50%);
      }

      #label-obstacles {
        top: 45%;
        right: 10%;
        transform: translateX(50%);
      }

      #label-past {
        top: 68%;
        left: 10%;
        transform: translateX(-50%);
      }

      #label-outcome {
        top: 68%;
        right: 10%;
        transform: translateX(50%);
      }

      .center-text {
        top: 37%;
      }

      .center-text h2 {
        font-size: 18px;
      }

      .center-text p {
        font-size: 14px;
      }

      #copyPanel #spreadCards {
        font-size: 11px;
      }

      #copyPanel #copyText {
        font-size: 13px;
      }
    }

    @media (max-width: 480px) {
      .horseshoe-container {
        min-height: clamp(480px, 65vh, 600px);
      }

      .card-position {
        width: clamp(55px, 16vw, 75px);
      }

      .center-text img {
        width: clamp(50px, 14vw, 75px);
      }

      .center-text .w3-button {
        font-size: 12px;
        padding: 3px 8px;
        margin: 0 2px;
      }

      #position-future,
      #position-present,
      #position-past {
        left: 8%;
      }

      #position-setting,
      #position-obstacles,
      #position-outcome {
        right: 8%;
      }

      #label-future,
      #label-present,
      #label-past {
        left: 8%;
      }

      #label-setting,
      #label-obstacles,
      #label-outcome {
        right: 8%;
      }
    }
  </style>
</head>

<body class="w3-black">

<!-- navbar -->
<div class="w3-top">
  <div class="w3-bar w3-black w3-left-align w3-small">
    <a href="index.html" class="w3-bar-item w3-button w3-white w3-hover-purple w3-padding"><i class="fa fa-home"></i></a>
    <a href="tarot_taropian_songs.html" class="w3-bar-item w3-button w3-hover-purple w3-padding">
