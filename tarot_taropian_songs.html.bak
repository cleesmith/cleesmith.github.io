        <div id="label-setting" class="card-label">Position 5: The Influence of Others</div>

        <!-- Card 4: Present (middle left) -->
        <div id="position-present" class="card-position">
          <img id="card4" src="images/0_Backs_tiff.jpg" onclick="onClick(this)">
          <div class="w3-container">
            <h6 id="title4" class="w3-center"></h6>
            <p id="cardNum4" hidden></p>
          </div>
        </div>
        <div id="label-present" class="card-label">Position 2: The Present</div>

        <!-- Card 5: Obstacles (middle right) -->
        <div id="position-obstacles" class="card-position">
          <img id="card5" src="images/0_Backs_tiff.jpg" onclick="onClick(this)">
          <div class="w3-container">
            <h6 id="title5" class="w3-center"></h6>
            <p id="cardNum5" hidden></p>
          </div>
        </div>
        <div id="label-obstacles" class="card-label">Position 6: Hopes and Fears</div>

        <!-- Card 6: Past (bottom left) -->
        <div id="position-past" class="card-position">
          <img id="card6" src="images/0_Backs_tiff.jpg" onclick="onClick(this)">
          <div class="w3-container">
            <h6 id="title6" class="w3-center"></h6>
            <p id="cardNum6" hidden></p>
          </div>
        </div>
        <div id="label-past" class="card-label">Position 1: The Past</div>

        <!-- Card 7: Outcome (bottom right) -->
        <div id="position-outcome" class="card-position">
          <img id="card7" src="images/0_Backs_tiff.jpg" onclick="onClick(this)">
          <div class="w3-container">
            <h6 id="title7" class="w3-center"></h6>
            <p id="cardNum7" hidden></p>
          </div>
        </div>
        <div id="label-outcome" class="card-label">Position 7: The Final Outcome</div>
      </div>

      <!-- Control Panel - sibling to horseshoe-container, inside wrapper -->
      <div id="copyPanel" style="display: none; margin-top:-50px;">
        <div class="w3-card-4">
          <div class="w3-container">
            <p id="spreadCards"></p>
          </div>
          <footer id="copyFooter" class="w3-container w3-blue" onclick="copyToClipboard()">
            <h5 id="copyText">copy to clipboard - get a general AI reading</h5>
          </footer>
        </div>
      </div>
      <br /><br /><br /><br />

    </div>
    <!-- End tarot-wrapper -->

  </div>
</div>

