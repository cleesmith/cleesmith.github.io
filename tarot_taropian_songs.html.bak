        <div id="label-you" class="card-label">Position 4: The Core Problem or Center of the Matter</div>

        <!-- Card 2: Future (top left) -->
        <div id="position-future" class="card-position">
          <img id="card2" src="images/0_Backs_tiff.jpg" onclick="onClick(this)">
